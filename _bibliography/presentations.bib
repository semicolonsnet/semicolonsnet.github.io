@inproceedings{Nordengren2014,
  title = {Identification of School Leaders in Small-n Cases Using Qualitative and Quantitative Network Analysis},
  booktitle = {American {{Educational Research Association}}},
  author = {Nordengren, Chase},
  year = {2014},
  pages = {30},
  abstract = {Social network analysis' concern with describing interdependent ties and constraints among individuals is promising for studying distributed leadership in schools. Network data can be analyzed qualitatively, quantitatively, or both. This paper examines a set of network data collected in a qualitative study on leadership in a dual language elementary school through qualitative analysis, principal selection, indegree centrality, and betweenness. It finds divergence between qualitative and quantitative analytic techniques, suggesting the need for strong theoretical support for particular analytic techniques.},
  keywords = {_tablet,methods: quantitative methods: sna},
  file = {/Users/chase/Zotero/storage/TTUTTYDL/Nordengren - 2014 - Identification of school leaders in small-n cases .pdf}
}

@session{Nordengren2018,
  type = {Concurrent Session},
  title = {Assessing Social-Emotional Learning: {{A}} Guide for the Perplexed},
  author = {Nordengren, Chase},
  year = {2018},
  month = nov,
  address = {{Honolulu, HI}},
  url = {https://doi.org/10.5281/zenodo.4321826},
  abstract = {A growing movement among educators, policymakers, and researchers seeks to better understand social-emotional learning (SEL): the inter- and intra-personal skills, mindsets, and dispositions that influence how students learn. NWEA has pioneered unique research in this space, including an assessment measuring how students' relationships and mindsets support their learning. This session will discuss what NWEA has learned through use of this instrument , how teachers and administrators use SEL data, and what is coming next in SEL assessment.  You'll leave the session with a clear understanding of where the field is headed, and how to best work with students now to improve their attitudes toward learning.},
  video = {https://www.youtube.com/watch?v=zK9MphNgAds},
  meeting = {Schools of the Future}
}

@session{Nordengren2020,
  type = {Concurrent Session},
  title = {Making It Work: {{Formative}} Assessment in Virtual Instruction},
  author = {Nordengren, Chase},
  year = {2020},
  month = nov,
  address = {{Virtual}},
  url = {https://doi.org/10.5281/zenodo.4323441},
  abstract = {If teaching is an art, then formative assessment\textemdash the planned, ongoing processes used to elicit and use evidence of student learning\textemdash is one of its fundamentals. During this singular moment in the lives of students, it has never been more important to understand student learning in the moment and use that understanding to drive instruction. As our research has shown, the learning gaps between students that will emerge during this period will likely be substantial. What we don't know is how this crisis will affect those students individually: where specifically students may fall behind and the specific content they will need to catch up. Formative assessment can help bridge the gaps in our understanding by going deep into what students know and can do, and providing students the opportunity to collaborate on the next steps in completing their unfinished learning.},
  video = {https://www.youtube.com/watch?v=hgt0gYuMgp4},
  meeting = {New York State Association for Computers and Technologies in Education}
}

