@inproceedings{Nordengren2012,
  title = {Collective Leadership Models in Educational Research: {{Towards}} a Focus on Theories of Action},
  booktitle = {University {{Council}} for {{Educational Administration Annual Convention}}},
  author = {Nordengren, Chase},
  year = {2012},
  pages = {63},
  abstract = {Background: Many models of educational leadership share a focus on collective action, in which teams of leaders utilize regular practices and routines to improve student outcomes. While consensus is forming in the research community around the use of collective models of leadership as a lens, researchers frequently cite a disconnect between leadership practices as studied and school improvement. Methodology: This literature review seeks to examine how quantitative and qualitative studies on collective leadership models conceptualize leadership influence on student outcomes. An inclusive approach gathered 73 relevant studies from 2000 to the present. A subgroup of 27 studies, containing both multiple leaders and a direct or indirect link to student outcomes, are analyzed in greater detail. Findings: Studies which identified a clear theory of action, resulting in improved student outcomes, produced the strongest findings. Three general theories of action are considered: leadership which enhances a school's ability to improve, leadership which creates shared school culture and leadership which re-designs teachers' work. These theories of action share three common features: the development of a common language, employing multiple levers of simultaneous change and promoting a collective focus on instruction. Conclusion: In keeping with other work, this review finds that relatively few studies in the field connect leadership activities with student outcomes and, of those that do, wide variation exists in leadership effects, in part based on how researchers understand leadership activities.},
  keywords = {_tablet,leadership: collective},
  file = {/Users/chase/Zotero/storage/UGQSPH82/Nordengren - 2012 - Collective leadership models in educational resear.pdf}
}

